{
  "name": "@prd-builder/mcp-server",
  "version": "0.1.0",
  "description": "MCP Server for the PRD Builder App \u2014 registers tools with UI metadata, handles tool calls, serves interactive UI resources",
  "main": "src/index.ts",
  "bin": {
    "prd-builder-mcp": "src/index.ts"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:http": "TRANSPORT=http tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "TRANSPORT=http node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@modelcontextprotocol/ext-apps": "^1.7.0",
    "@prd-builder/shared": "*",
    "@prd-builder/engine": "*",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "@types/express": "^4.17.21"
  }
}
